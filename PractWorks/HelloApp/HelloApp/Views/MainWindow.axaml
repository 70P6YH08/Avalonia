<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HelloApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:helloapp="using:HelloApp"
        xmlns:local="using:HelloApp.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:net="using:System.Net"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="HelloApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="HelloApp">
    <StackPanel>

        <!--Pr 6-->
        <!--<local:StylesView/>-->
            
        <!--<ContentControl Content="{Binding CurrentPage}">
        </ContentControl>
	    <Button Content="Авторизироваться" Command="{Binding AuthCommand}"/>
	    <Button Content="Зарегистрироваться" Command="{Binding RegCommand}"/>-->

        <ContentControl Content="{Binding Navigation.CurrentViewModel}">
        </ContentControl>
	    <Button Content="Авторизироваться" Command="{Binding AuthCommand}"/>
	    <Button Content="Зарегистрироваться" Command="{Binding RegCommand}"/>
	    <Button Content="Назад" Command="{Binding GoBackCommand}"/>
    </StackPanel>
</Window>
